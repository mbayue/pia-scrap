# Optional account login
NOVELPIA_EMAIL=your_email@example.com
NOVELPIA_PASSWORD=your_password

# Optional Netscape cookie auth for ad-gated/premium/image chapters
# Use either a server-local cookies.txt path:
NOVELPIA_COOKIE_FILE=cookies.txt

# Or paste cookies as base64-encoded Netscape text:
# PowerShell: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes((Get-Content .\cookies.txt -Raw)))
NOVELPIA_COOKIE_TEXT_B64=

# Optional fallback login-at token if your cookie export does not include LOGINAT/login_at
NOVELPIA_LOGIN_AT=
